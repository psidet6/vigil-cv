# Vigil CV container deployment example.
# Copy this file to .env next to compose.yaml.

HOST_PORT=5001
APP_HOST=0.0.0.0
APP_PORT=5001
FLASK_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_SECRET
MODEL_DEFAULT=general
YOLO_TELEMETRY=false

# Unified PostgreSQL data source.
# Image query, SMS outbox, person context, and face-library sync all use this connection.
POSTGRES_ENABLED=false
POSTGRES_HOST=postgres.example.com
POSTGRES_PORT=5432
POSTGRES_DB=vigil_cv
POSTGRES_USER=app_user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_CONNECT_TIMEOUT=10
POSTGRES_SOURCE_IMAGE_TABLE=sample_schema.source_image_table
POSTGRES_IMAGE_URL_COLUMN=image_url
POSTGRES_IMAGE_TIME_COLUMN=capture_time
POSTGRES_IMAGE_HOUR_COLUMN=capture_hour
POSTGRES_PERSON_CONTEXT_TABLE=sample_schema.person_context
POSTGRES_PERSON_ID_COLUMN=gmsfhm
POSTGRES_SMS_OUTBOX_TABLE=sample_schema.sms_outbox
POSTGRES_FACE_QUERY_PATH=/app/modules/face/sql/face_library.sql

# Runtime paths inside the container.
MODEL_PATH=/app/model/special_event_detector.pt
MODEL_PATH_GENERAL=/app/model/yolov8s-worldv2.pt
MOBILECLIP_TS_PATH=/app/model/mobileclip_blt.ts
CLIP_VIT_B32_PATH=/app/model/ViT-B-32.pt
FACE_MODEL_DET=/app/model/det_10g.onnx
FACE_MODEL_REC=/app/model/w600k_r50.onnx
OUTPUT_DIR=/data/output
RESULTS_DIR=/data/output/_results
SQLITE_DB_PATH=/data/jobs.sqlite3
UPLOAD_TEMP_DIR=/data/upload_tmp
FACE_DATA_DIR=/data/face_data
DATASETS_DIR=/data/datasets
TRAIN_RUNS_DIR=/data/train_runs

# Face library.
FACE_SIMILARITY_THR=0.35
FACE_MATCH_TOP_K=5
FACE_BLUR_THRESH=60

# Detection runtime.
MAX_WORKERS=8
MAX_UPLOAD_BYTES=1073741824
CONF_THRESH=0.7
BATCH_SIZE=8
IMGSZ=640
VIDEO_FRAME_INTERVAL=5
JOB_RETENTION_DAYS=0

# Dispatch platform.
DISPATCH_AUTH_URL=http://dispatch.example.com/oauth/token
DISPATCH_TASK_URL=http://dispatch.example.com/api/tasks
DISPATCH_CLIENT_ID=CHANGE_ME
DISPATCH_CLIENT_SECRET=CHANGE_ME
DISPATCH_GRANT_TYPE=password
DISPATCH_RWYID=CHANGE_ME
DISPATCH_SJCSLY=vigil-cv
DISPATCH_QSSX=06
DISPATCH_FKSX=08
DISPATCH_GJDQ=CHN
DISPATCH_ZJLX=111
DISPATCH_XFDW=
DISPATCH_YWFZR=
DISPATCH_YWFZRLXDH=
DISPATCH_DEFAULT_TITLE=Risk Review Task
DISPATCH_DEFAULT_CONTENT=Please verify the generated risk review item.
DISPATCH_DEFAULT_NOTE=Generated by Vigil CV. Please verify against business context.
DISPATCH_MOCK_MODE=true
DISPATCH_QUEUE_LIMIT=100

# SMS reminder. Used only when DISPATCH_MOCK_MODE=false.
DISPATCH_SMS_DEFAULT_MOBILE=
DISPATCH_SMS_DEFAULT_TEMPLATE=[Demo] {xm}, please confirm {illegal_type} before {deadline}. Unit: {zbpcsmc}, phone: {ywfzrlxdh}.
DISPATCH_SMS_USERID=CHANGE_ME
DISPATCH_SMS_PASSWORD=CHANGE_ME
DISPATCH_SMS_USERPORT=0006
